# RankWrangler Stack Internal Caddy Configuration
# This handles routing within the stack (nginx replacement)

{
    # Disable admin API for security in production
    admin off
    
    # Enable JSON logging
    log {
        output stdout
        format json
    }
    
    # Auto HTTPS off (SSL handled at server level)
    auto_https off
}

# Listen on port 80 (internal to stack)
:80 {
    # Enable access logs
    log {
        output stdout
        format json
    }
    
    # API routes to RankWrangler server
    handle /api/* {
        reverse_proxy server:8080 {
            # Health checks
            health_uri /api/health
            health_interval 30s
            health_timeout 10s
            
            # Load balancing (single backend, but good for monitoring)
            fail_duration 30s
            max_fails 3
            
            # Forward headers for proper client info
            header_up Host {http.request.host}
            header_up X-Real-IP {http.request.remote}
            header_up X-Forwarded-For {http.request.remote}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up X-Forwarded-Host {http.request.host}
        }
    }
    
    # Nginx health check endpoint for monitoring
    handle /nginx-health {
        respond "healthy" 200
    }
    
    # Caddy health check endpoint
    handle /caddy-health {
        header Content-Type application/json
        respond `{"status":"ok","service":"rankwrangler-caddy"}` 200
    }
    
    # Catch-all for non-API requests
    handle * {
        header Content-Type application/json
        respond `{"error": "Not Found", "message": "This endpoint does not exist. Use /api/* endpoints."}` 404
    }
}