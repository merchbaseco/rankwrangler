{
    "name": "rankwrangler-extension",
    "private": true,
    "description": "RankWrangler Extension",
    "version": "0.1.2",
    "main": "index.js",
    "scripts": {
        "prepare": "tw-patch install",
        "start": "concurrently \"bun run dev\" \"bun run build\"",
        "preview:chrome": "VITE_PREVIEW_CHROME=true vite --open /preview.html",
        "tailwind": "tailwindcss -i src/styles/index.css -o dist/assets/index.css",
        "dev": "vite",
        "build:deps": "bun run --cwd ../.. http-client:build",
        "build": "bun run build:deps && tsc && bun run build:clean && bun run build:background && bun run build:popup && bun run build:content",
        "build:clean": "rm -rf dist",
        "build:background": "vite build --config vite.config.background.ts",
        "build:popup": "vite build --config vite.config.popup.ts",
        "build:content": "vite build --config vite.config.content.ts",
        "build:safari": "node scripts/build-safari.js",
        "build:chrome": "node scripts/build-chrome.js",
        "preview": "vite preview",
        "lint": "biome check src/",
        "lint:fix": "biome check --write --unsafe src/"
    },
    "author": "RankWrangler",
    "license": "ISC",
    "devDependencies": {
        "@biomejs/biome": "2.3.14",
        "@tailwindcss/vite": "4.1.18",
        "@types/chrome": "0.0.240",
        "@types/fs-extra": "11.0.4",
        "@types/node": "24.10.12",
        "@types/react": "18.3.28",
        "@types/react-dom": "18.3.7",
        "@types/webextension-polyfill": "0.10.7",
        "@vitejs/plugin-react": "5.1.3",
        "concurrently": "8.2.2",
        "esno": "0.16.3",
        "fs-extra": "11.3.3",
        "prettier": "3.8.1",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "rollup": "4.60.4",
        "tailwindcss": "4.1.18",
        "tailwindcss-patch": "7.1.6",
        "terser": "5.46.0",
        "ts-node": "10.9.2",
        "typescript": "5.9.3",
        "ultracite": "7.1.5",
        "vite": "7.3.3",
        "vite-plugin-singlefile": "2.3.0",
        "vite-plugin-static-copy": "3.2.0",
        "webext-bridge": "6.0.1",
        "webextension-polyfill": "0.10.0",
        "webextension-polyfill-ts": "0.26.0"
    },
    "dependencies": {
        "@rankwrangler/history-chart": "workspace:*",
        "@radix-ui/react-separator": "1.1.8",
        "@radix-ui/react-slot": "1.2.4",
        "@radix-ui/react-switch": "1.2.6",
        "@rankwrangler/http-client": "^0.5.0",
        "@tanstack/react-query": "5.90.20",
        "class-variance-authority": "0.7.1",
        "clsx": "2.1.1",
        "consola": "3.4.2",
        "dexie": "4.3.0",
        "limiter": "3.0.0",
        "lucide-react": "0.560.0",
        "recharts": "3.7.0",
        "react-day-picker": "9.13.2",
        "p-limit": "5.0.0",
        "tailwind-merge": "3.4.0",
        "zod": "4.3.6"
    },
    "packageManager": "bun@1.1.27"
}
