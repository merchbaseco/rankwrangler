    "restart": "./scripts/commands.sh restart",
    "stop": "./scripts/commands.sh stop"
  },
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/helmet": "^13.0.1",
    "@t3-oss/env-core": "^0.13.8",
    "amazon-sp-api": "^1.1.6",
    "bottleneck": "^2.19.5",
    "drizzle-orm": "^0.44.4",
    "fastify": "^5.5.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.1.5",
    "node-cache": "^5.1.2",
    "pg": "^8.16.3",
    "postgres": "^3.4.7",
    "tslib": "^2.8.1",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "@types/pg": "^8",
    "dotenv-cli": "^10.0.0",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.20.4",
