{
    "name": "@rankwrangler/server",
    "private": true,
    "version": "0.5.0",
    "description": "Docker-deployable SP-API service for Amazon catalog search",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "vite build",
        "dev": "dotenv -e ../../.env -- sh -c 'export DISABLE_SERVER_JOB_RUNNER=${DISABLE_SERVER_JOB_RUNNER:-true}; exec tsx src/index.ts'",
        "dev:jobs": "dotenv -e ../../.env -- env DISABLE_SERVER_JOB_RUNNER=false tsx src/index.ts",
        "start": "dotenv -e ../../.env node dist/index.js",
        "cli": "tsx src/cli.ts"
    },
    "dependencies": {
        "@rankwrangler/http-client": "workspace:*",
        "@amazon-sp-api-release/amazon-sp-api-sdk-js": "1.7.1",
        "@clerk/backend": "2.33.3",
        "@fastify/cors": "11.2.0",
        "@fastify/helmet": "13.0.2",
        "@t3-oss/env-core": "0.13.10",
        "@trpc/client": "11.10.0",
        "@trpc/server": "11.10.0",
        "bottleneck": "2.19.5",
        "date-fns": "4.1.0",
        "date-fns-tz": "3.2.0",
        "drizzle-orm": "0.45.2",
        "fastify": "5.8.5",
        "jsonwebtoken": "9.0.3",
        "nanoid": "5.1.6",
        "node-cache": "5.1.2",
        "pg": "8.18.0",
        "pg-boss": "12.9.0",
        "postgres": "3.4.8",
        "tslib": "2.8.1",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@biomejs/biome": "2.3.14",
        "@types/jsonwebtoken": "9.0.10",
        "@types/node": "24.10.12",
        "@types/pg": "8.16.0",
        "dotenv-cli": "10.0.0",
        "drizzle-kit": "0.31.10",
        "tsx": "4.21.0",
        "typescript": "5.9.3",
        "ultracite": "7.1.5",
        "vite": "7.3.3"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "packageManager": "bun@1.1.27"
}
