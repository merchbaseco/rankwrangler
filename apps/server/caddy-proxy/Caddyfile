# RankWrangler Server-Level Caddy Configuration
# This replaces nginx-proxy-manager for SSL and domain routing

{
    # Enable JSON logging
    log {
        output stdout
        format json
    }
    
    # Email for Let's Encrypt (replace with your email)
    email admin@merchbase.co
    
    # Use Let's Encrypt production (comment out for staging)
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# Portainer subdomain
portainer.merchbase.co {
    # Enable access logs
    log {
        output stdout
        format json
    }
    
    # Route to Portainer container
    reverse_proxy portainer:9000 {
        # Forward headers for proper client info
        header_up Host {http.request.host}
        header_up X-Real-IP {http.request.remote.host}
        header_up X-Forwarded-For {http.request.remote.host}
        header_up X-Forwarded-Proto {http.request.scheme}
        header_up X-Forwarded-Host {http.request.host}
    }
}

# Main merchbase.co domain with automatic HTTPS
merchbase.co {
    # Enable access logs
    log {
        output stdout
        format json
    }
    
    # API routes to RankWrangler stack
    handle /api/* {
        reverse_proxy 172.17.0.1:8090 {
            # Health checks
            health_uri /api/health
            health_interval 30s
            health_timeout 10s
            
            # Fail handling
            fail_duration 30s
            max_fails 3
            
            # Forward headers for proper client info
            header_up Host {http.request.host}
            header_up X-Real-IP {http.request.remote.host}
            header_up X-Forwarded-For {http.request.remote.host}
            header_up X-Forwarded-Proto {http.request.scheme}
            header_up X-Forwarded-Host {http.request.host}
        }
    }
    
    # Optional: If you want to keep serving merchbase UI
    # Uncomment and adjust if needed
    # handle /* {
    #     reverse_proxy merchbase:3000
    # }
    
    # For now, redirect root to a simple message
    handle /* {
        header Content-Type text/html
        respond `<!DOCTYPE html>
<html>
<head>
    <title>MerchBase API</title>
    <style>
        body { font-family: Arial, sans-serif; text-align: center; margin-top: 100px; }
        .container { max-width: 600px; margin: 0 auto; }
        .api-link { background: #0066cc; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; }
    </style>
</head>
<body>
    <div class="container">
        <h1>MerchBase API Server</h1>
        <p>This is the RankWrangler API endpoint.</p>
        <a href="/api/health" class="api-link">Check API Health</a>
    </div>
</body>
</html>` 200
    }
}