{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": [
    "**/.env"
  ],
  "tasks": {
    "@rankwrangler/web-extension#build": {
      "outputs": [
        "dist/**"
      ]
    },
    "@rankwrangler/safari-extension#build": {
      "dependsOn": [
        "@rankwrangler/web-extension#build"
      ],
      "outputs": [
        "**/Resources/**"
      ]
    },
    "@rankwrangler/server#build": {
      "outputs": [
        "dist/**"
      ]
    },
    "@rankwrangler/server#start": {
      "dependsOn": [
        "@rankwrangler/server#build"
      ]
    },
    "@rankwrangler/server#deploy": {
      "dependsOn": [
        "@rankwrangler/server#build"
      ]
    },
    "clean": {
      "cache": false
    },
    "lint": {},
    "format": {},
    "@rankwrangler/marketing#build": {
      "outputs": [
        "dist/**"
      ]
    },
    "@rankwrangler/marketing#dev": {}
  },
  "ui": "tui"
}