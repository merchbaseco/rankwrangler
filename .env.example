# Database
DATABASE_PASSWORD=your_secure_password_here
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=rankwrangler
DATABASE_USER=rankwrangler

# Amazon SP-API Configuration
SPAPI_REFRESH_TOKEN=your_spapi_refresh_token_here
SPAPI_CLIENT_ID=your_spapi_client_id_here
SPAPI_APP_CLIENT_SECRET=your_spapi_app_client_secret_here

# Clerk Authentication (REQUIRED)
CLERK_SECRET_KEY=your_clerk_secret_key_here
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here
DEV_CLERK_SIGN_IN_USER_ID=your_clerk_dev_user_id_here
VITE_DEV_CLERK_AUTO_SIGN_IN=false

# License System Configuration (REQUIRED)
LICENSE_SECRET=your_64_character_random_string_for_jwt_signing_here_make_it_secure
SESSION_SECRET=your_32_character_random_string_for_admin_sessions_here

# Admin Configuration (OPTIONAL - if not set, admin APIs are disabled)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD_HASH=your_bcrypt_hashed_password_here

# Analytics (OPTIONAL)
POSTHOG_API_KEY=your_posthog_key_here
KEEPA_API_KEY=your_keepa_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Website (OPTIONAL)
VITE_API_URL=http://localhost:8080
WEBSITE_API_PROXY_TARGET=http://localhost:8080

# Notes:
# - Copy this file to ../.env (repo root) and fill in your values
# - Escape $ characters as $$ in docker-compose (e.g., password hashes)
# - Postgres host port is 5433
# - To generate a bcrypt password hash:
#   node -e "console.log(require('bcrypt').hashSync('your_password', 10))"
