{
    "name": "rankwrangler",
    "private": true,
    "workspaces": ["apps/*", "packages/*"],
    "packageManager": "bun@1.1.27",
    "scripts": {
        "dev": "concurrently -k -n server,website -c cyan,magenta \"bun run --filter @rankwrangler/server --elide-lines=0 dev\" \"bun run --filter @rankwrangler/website dev\"",
        "server:dev": "bun run --filter @rankwrangler/server dev",
        "server:build": "bun run --filter @rankwrangler/server build",
        "server:start": "bun run --filter @rankwrangler/server start",
        "server:cli": "bun run --filter @rankwrangler/server cli",
        "cli:build": "bun run http-client:build && bun run --filter @merchbase/rankwrangler-cli build",
        "website:dev": "bun run --filter @rankwrangler/website dev",
        "website:build": "bun run --filter @rankwrangler/website build",
        "website:preview": "bun run --filter @rankwrangler/website preview",
        "extension:prepare": "bun run --filter rankwrangler-extension prepare",
        "extension:start": "bun run --filter rankwrangler-extension start",
        "extension:tailwind": "bun run --filter rankwrangler-extension tailwind",
        "extension:dev": "bun run --filter rankwrangler-extension dev",
        "extension:build": "bun run --filter rankwrangler-extension build",
        "extension:build:clean": "bun run --filter rankwrangler-extension build:clean",
        "extension:build:background": "bun run --filter rankwrangler-extension build:background",
        "extension:build:popup": "bun run --filter rankwrangler-extension build:popup",
        "extension:build:content": "bun run --filter rankwrangler-extension build:content",
        "extension:build:safari": "bun run --filter rankwrangler-extension build:safari",
        "extension:build:chrome": "bun run --filter rankwrangler-extension build:chrome",
        "extension:preview": "bun run --filter rankwrangler-extension preview",
        "extension:lint": "bun run --filter rankwrangler-extension lint",
        "extension:lint:fix": "bun run --filter rankwrangler-extension lint:fix",
        "build:clean": "bun run --filter rankwrangler-extension build:clean",
        "build:background": "bun run --filter rankwrangler-extension build:background",
        "build:popup": "bun run --filter rankwrangler-extension build:popup",
        "build:content": "bun run --filter rankwrangler-extension build:content",
        "build:safari": "bun run --filter rankwrangler-extension build:safari",
        "build:chrome": "bun run --filter rankwrangler-extension build:chrome",
        "tailwind": "bun run --filter rankwrangler-extension tailwind",
        "lint": "bun run --filter rankwrangler-extension lint",
        "lint:fix": "bun run --filter rankwrangler-extension lint:fix",
        "http-client:types": "dts-bundle-generator --no-check -o packages/http-client/src/app-router.d.ts apps/server/src/api/router-public.ts --project tsconfig.http-client.json",
        "http-client:build": "bun run http-client:types && tsc -p packages/http-client/tsconfig.json && cp packages/http-client/src/app-router.d.ts packages/http-client/dist/app-router.d.ts"
    },
    "devDependencies": {
        "concurrently": "^8.2.2",
        "dts-bundle-generator": "^9.5.1",
        "typescript": "^5.9.3"
    }
}
