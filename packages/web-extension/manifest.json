{
  "manifest_version": 3,
  "name": "RankWrangler",
  "version": "1.0",
  "description": "Track and analyze Amazon product rankings and metrics in real-time",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": ["*://*.amazon.com/*", "https://merchbase.co/api/*"],
  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.amazon.com/s*"],
      "js": ["content.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://www.amazon.com/dp/*",
        "https://www.amazon.com/*/dp/*",
        "https://www.amazon.com/gp/product/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "resources": ["popup.js", "background.js"]
    }
  ]
}
