{
    "name": "@rankwrangler/http-client",
    "version": "0.2.3",
    "description": "Typed tRPC client for RankWrangler",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
